---
import Base from '../layouts/Base.astro';
import { site } from '../config';

const services = [
  { id: 'discovery', idx: '01', title: 'Discovery & Consulting', body: 'Before any code gets written, we figure out what actually needs to be built. Requirements research, audits of what you already have, and a technical roadmap you can act on — with or without us.', chips: ['Requirements research', 'System audit', 'Tech strategy', 'Architecture'] },
  { id: 'web', idx: '02', title: 'Websites & Landing Pages', body: 'Company profiles, marketing sites and landing pages for startups and growing businesses — fast, content-first, and built to be found.', chips: ['Company profile', 'Landing pages', 'CMS', 'Technical SEO'] },
  { id: 'webapp', idx: '03', title: 'Web Apps & Dashboards', body: 'Custom web applications and internal dashboards built around how your team actually works — authentication, roles, reporting, the lot.', chips: ['Custom web apps', 'Admin dashboards', 'Auth & roles', 'API design'] },
  { id: 'systems', idx: '04', title: 'Systems Integration & Custom Software', body: 'Custom information systems, CMS platforms and integrations that connect the tools your business already runs on — built for businesses outgrowing off-the-shelf software, and as a technical partner for agencies who need engineering hands.', chips: ['System integration', 'Custom CMS', 'Sistem informasi', 'Automation'] },
  { id: 'ecommerce', idx: '05', title: 'E-commerce', body: 'Online stores with payments, inventory and checkout flows that don’t fall apart at scale.', chips: ['Online stores', 'Payment integration', 'Inventory', 'Checkout UX'] },
  { id: 'desktop', idx: '06', title: 'Desktop Applications', body: 'Cross-platform desktop tools for the workflows that don’t belong in a browser tab.', chips: ['Desktop apps', 'Internal tools', 'Cross-platform', 'Offline-first'] },
  { id: 'care', idx: '07', title: 'Care & Growth', body: 'A relationship, not a hand-off. Hosting, monitoring, fixes and a steady stream of improvements once it’s live.', chips: ['Maintenance', 'Hosting', 'Monitoring', 'Retainers'] },
];

const faq = [
  { q: 'How long does a project take?', a: 'It depends a lot on what you’re building — a landing page might take 2–4 weeks, while a custom system or full web app usually runs 8 weeks or more. We’ll give you a realistic timeline after a quick discovery call.' },
  { q: 'Do you work with our existing brand or systems?', a: 'Yes. If you already have something working — a brand, a legacy system, an existing codebase — we build on it. If it needs rethinking, we can do that too.' },
  { q: 'What technology do you use?', a: 'We’re stack-agnostic and pick tools that fit the problem and your team, whether that’s a web front-end, a desktop app, or wiring two systems together.' },
  { q: 'Can you just help us figure out what we actually need?', a: 'Yes — a lot of engagements start as discovery or consulting before a single line of code gets written. No obligation to continue past that.' },
  { q: 'Do you work with other agencies?', a: 'Often, yes. We partner with design and marketing agencies as their technical team — white-label or co-branded, whichever fits the relationship.' },
];

const servicesJsonLd = services.map((s) => ({
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: s.title,
  description: s.body,
  provider: { '@type': 'Organization', name: site.name, url: site.url },
}));

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Base
  title="Services"
  description="Discovery, websites, web apps, systems integration, e-commerce, desktop software and ongoing care. The full range of how FORTA builds."
  mainLabel="Services"
  jsonLd={[...servicesJsonLd, faqJsonLd]}
>
  <section class="page-hero wrap">
    <div class="eyebrow" data-reveal>What we do</div>
    <h1 class="display h-xl" data-reveal style="margin-top:24px; max-width:16ch;">
      End-to-end, or<br>exactly where<br>you <span class="accent">need us</span>.
    </h1>
    <p class="lead" data-reveal data-reveal-delay="1" style="margin-top:32px;">
      Seven disciplines, one team. Bring us a blank page, a legacy system, or a business
      process that's outgrown its tools — we'll meet you wherever the work is.
    </p>
  </section>

  <!-- Detailed services -->
  <section class="section-sm wrap">
    {services.map((s) => (
      <article class="step" data-reveal id={s.id}>
        <span class="idx">{s.idx}</span>
        <div>
          <h3>{s.title}</h3>
          <p>{s.body}</p>
          <div class="tags">{s.chips.map((c) => <span class="chip">{c}</span>)}</div>
        </div>
      </article>
    ))}
  </section>

  <!-- Engagement models -->
  <section class="section wrap">
    <div class="eyebrow" data-reveal>Ways to work together</div>
    <h2 class="display h-lg" data-reveal style="margin-top:18px; margin-bottom:48px;">Pick a starting point.</h2>
    <div class="grid cols-3">
      <div class="step" style="border-top-color:var(--line-strong);" data-reveal>
        <div>
          <div class="mono accent">A — Discovery</div>
          <h3 style="margin-top:14px;">Audit & Roadmap</h3>
          <p>A focused deep dive into what you have and what you actually need, ending in a clear, prioritised plan.</p>
          <p class="mono" style="margin-top:20px; color:var(--paper);">Scoped after a quick call</p>
        </div>
      </div>
      <div class="step" style="border-top-color:var(--accent);" data-reveal data-reveal-delay="1">
        <div>
          <div class="mono accent">B — Project</div>
          <h3 style="margin-top:14px;">Full Build</h3>
          <p>Design and development of a complete website, web app, or system — start to launch. Our most common engagement.</p>
          <p class="mono" style="margin-top:20px; color:var(--paper);">Scoped after a quick call</p>
        </div>
      </div>
      <div class="step" style="border-top-color:var(--line-strong);" data-reveal data-reveal-delay="2">
        <div>
          <div class="mono accent">C — Retainer</div>
          <h3 style="margin-top:14px;">Ongoing Partner</h3>
          <p>A monthly block of development time to keep improving, integrating and shipping after launch.</p>
          <p class="mono" style="margin-top:20px; color:var(--paper);">Scoped after a quick call</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section wrap">
    <div class="two-col">
      <div class="sticky-col">
        <div class="eyebrow" data-reveal>Good to know</div>
        <h2 class="display h-lg" data-reveal style="margin-top:18px;">Questions,<br>answered.</h2>
      </div>
      <div>
        {faq.map((f) => (
          <details class="step" data-reveal style="cursor:pointer;">
            <summary style="list-style:none;"><h3 style="display:inline;">{f.q}</h3></summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <section class="section wrap cta-band">
    <div class="eyebrow" data-reveal style="justify-content:center;">Next step</div>
    <h2 class="display" data-reveal style="margin-top:24px;">Tell us what<br><span class="stroke">you're building.</span></h2>
    <div style="margin-top:48px;" data-reveal data-reveal-delay="1">
      <a href="/contact" class="btn btn--accent" data-magnetic style="font-size:.9rem; padding:1.1em 1.8em;">Start a project <span class="arrow">↗</span></a>
    </div>
  </section>
</Base>
