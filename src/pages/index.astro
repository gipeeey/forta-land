---
import Base from '../layouts/Base.astro';
import { site } from '../config';

const services = [
  { n: '01', title: 'Discovery & Consulting', desc: 'Requirements research and system audits that tell you exactly what needs to be built, before a line of code gets written.' },
  { n: '02', title: 'Websites & Landing Pages', desc: 'Company profiles and landing pages for startups and growing businesses — fast, content-first, no bloated templates.' },
  { n: '03', title: 'Web Apps & Dashboards', desc: 'Custom web applications and admin dashboards built around how your team actually works.' },
  { n: '04', title: 'Systems Integration & Custom Software', desc: 'Custom CMS, sistem informasi, and integrations connecting the tools your business already runs on.' },
  { n: '05', title: 'E-commerce', desc: 'Online stores with payments, inventory and checkout flows that hold up at scale.' },
  { n: '06', title: 'Desktop Applications', desc: 'Cross-platform desktop tools for the workflows that don\'t belong in a browser tab.' },
  { n: '07', title: 'Care & Growth', desc: 'Ongoing support and a steady stream of improvements that keep things running long after launch.' },
];
---

<Base
  title={`${site.name} — Software Studio`}
  description={site.description}
  mainLabel="Home"
>
  <!-- HERO -->
  <section class="hero wrap">
    <div class="hero-title">
      <div class="eyebrow" data-reveal>{site.tagline} · Est. {site.founded}</div>
      <h1 class="display h-xxl" style="margin-top:24px;">
        <span class="line-mask" data-reveal><span>We build</span></span>
        <span class="line-mask" data-reveal data-reveal-delay="1"><span>software <span class="accent mono-em">worth</span></span></span>
        <span class="line-mask" data-reveal data-reveal-delay="2"><span>running.</span></span>
      </h1>
    </div>
    <div class="hero-meta">
      <p class="lead" data-reveal data-reveal-delay="2">
        A studio for teams that need more than a website — we research, design, build and
        integrate the systems your business actually runs on.
      </p>
      <div class="scroll-cue mono" data-reveal data-reveal-delay="3">
        <span class="track"></span> Scroll to explore
      </div>
    </div>
  </section>

  <!-- MARQUEE -->
  <div class="marquee" aria-hidden="true">
    <div class="marquee-track">
      <span>Web Apps</span><span>Systems Integration</span><span>Custom CMS</span><span>Desktop Apps</span><span>E-commerce</span><span>Consulting</span>
    </div>
  </div>

  <!-- MANIFESTO -->
  <section class="section wrap">
    <div class="two-col">
      <div class="mono" data-reveal>(01) — What we believe</div>
      <div>
        <p class="display h-md" data-reveal style="line-height:1.18;">
          Most software is a template wearing a different logo. We build the
          other kind — <span class="accent">fast, considered, and built for what's next</span>.
          Every screen, every integration earns its place.
        </p>
        <div style="margin-top:48px;" data-reveal data-reveal-delay="1">
          <a href="/about" class="tlink">Meet the studio →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="section wrap" id="services">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:24px; margin-bottom:40px;">
      <div>
        <div class="eyebrow" data-reveal>What we do</div>
        <h2 class="display h-lg" data-reveal style="margin-top:18px;">Seven ways we help.</h2>
      </div>
      <a href="/services" class="tlink" data-reveal>All services →</a>
    </div>

    <div class="svc-list">
      {services.map((s) => (
        <a class="svc-row" href="/services" data-reveal>
          <span class="num">{s.n}</span>
          <div><h3>{s.title}</h3></div>
          <span class="plus">+</span>
          <p class="svc-desc" style="grid-column:2;">{s.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- SELECTED WORK -->
  <section class="section wrap" id="work">
    <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:24px; margin-bottom:44px;">
      <div>
        <div class="eyebrow" data-reveal>Selected work</div>
        <h2 class="display h-lg" data-reveal style="margin-top:18px;">Building <span class="accent mono-em">in public</span>.</h2>
      </div>
      <span class="mono" data-reveal>(02) — First case studies, 2026</span>
    </div>

    <a href="/contact" class="work-card" data-reveal>
      <div class="ph" style="aspect-ratio:16/8; border-radius:16px;"><div class="img-inner"><span class="label">In progress</span></div><div class="scrim"></div></div>
      <div class="meta">
        <div><h3 style="font-size:clamp(1.5rem,2.8vw,2.3rem);">Our first client engagements are being built right now</h3></div>
        <span class="tags">Web apps · Systems · Commerce</span>
      </div>
    </a>

    <p class="body" data-reveal data-reveal-delay="1" style="max-width:54ch; margin-top:28px;">
      We launched in {site.founded} and chose to work in the open. Real case studies land
      here the moment they ship — until then, here's the kind of work we take on.
    </p>

    <div class="grid cols-3" style="margin-top:56px;">
      <div class="step" style="border-top-color:var(--line-strong);" data-reveal>
        <span class="idx">01</span>
        <div><h3 style="font-size:clamp(1.3rem,2.4vw,1.7rem);">Web apps &amp; dashboards</h3><p>Custom applications and internal tools built around how your team actually works.</p></div>
      </div>
      <div class="step" style="border-top-color:var(--line-strong);" data-reveal data-reveal-delay="1">
        <span class="idx">02</span>
        <div><h3 style="font-size:clamp(1.3rem,2.4vw,1.7rem);">Systems &amp; integration</h3><p>Custom CMS, information systems and integrations across the tools you already run.</p></div>
      </div>
      <div class="step" style="border-top-color:var(--line-strong);" data-reveal data-reveal-delay="2">
        <span class="idx">03</span>
        <div><h3 style="font-size:clamp(1.3rem,2.4vw,1.7rem);">Commerce &amp; growth</h3><p>Online stores and the ongoing improvements that keep them converting after launch.</p></div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="section-sm wrap">
    <div class="grid cols-4">
      <div class="stat" data-reveal><div class="num">0<span class="accent"> templates</span></div><div class="cap">Every build starts from your actual problem, not a theme.</div></div>
      <div class="stat" data-reveal data-reveal-delay="1"><div class="num">100<span class="accent">% senior</span></div><div class="cap">No junior hand-offs — the people who scope it build it.</div></div>
      <div class="stat" data-reveal data-reveal-delay="2"><div class="num">1<span class="accent"> team</span></div><div class="cap">Design, engineering and systems work under one roof.</div></div>
      <div class="stat" data-reveal data-reveal-delay="3"><div class="num">&lt;48<span class="accent">hr</span></div><div class="cap">Typical first reply once you reach out.</div></div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="section wrap">
    <div class="two-col">
      <div class="sticky-col">
        <div class="eyebrow" data-reveal>How we work</div>
        <h2 class="display h-lg" data-reveal style="margin-top:18px;">A process<br>with no waste.</h2>
        <p class="body" data-reveal data-reveal-delay="1" style="margin-top:24px; max-width:34ch;">
          Four phases, fully collaborative. You're never guessing where the project stands.
        </p>
      </div>
      <div>
        <div class="step" data-reveal><span class="idx">01</span><div><h3>Discover</h3><p>We audit what exists, talk to your team, and pin down the one problem the project has to solve.</p><div class="tags"><span class="chip">Audit</span><span class="chip">Strategy</span><span class="chip">Research</span></div></div></div>
        <div class="step" data-reveal><span class="idx">02</span><div><h3>Define</h3><p>Architecture, sitemap or system design. We agree on direction before a single screen or schema is built.</p><div class="tags"><span class="chip">Architecture</span><span class="chip">System design</span></div></div></div>
        <div class="step" data-reveal><span class="idx">03</span><div><h3>Design & Build</h3><p>Designed and developed in tight loops — you see real, working software early and often.</p><div class="tags"><span class="chip">UI design</span><span class="chip">Front-end</span><span class="chip">Backend</span><span class="chip">Integrations</span></div></div></div>
        <div class="step" data-reveal><span class="idx">04</span><div><h3>Launch & Grow</h3><p>We ship, measure and keep refining. Good systems are never really finished.</p><div class="tags"><span class="chip">QA</span><span class="chip">Monitoring</span><span class="chip">Iteration</span></div></div></div>
      </div>
    </div>
  </section>

  <!-- VALUE STATEMENT -->
  <section class="section wrap">
    <div style="max-width:24ch;" class="mono" data-reveal>(03) — What client work means to us</div>
    <blockquote class="quote display" data-reveal style="margin-top:32px; max-width:24ch;">
      No middlemen, no junior hand-offs. <span class="accent">You talk to the people building it</span>, from the first call to the day it ships.
    </blockquote>
  </section>

  <!-- CTA BAND -->
  <section class="section wrap cta-band">
    <div class="eyebrow" data-reveal style="justify-content:center;">Let's build</div>
    <h2 class="display" data-reveal style="margin-top:24px;">
      Have a project<br><span class="stroke">in mind?</span>
    </h2>
    <div style="margin-top:48px;" data-reveal data-reveal-delay="1">
      <a href="/contact" class="btn btn--accent" data-magnetic style="font-size:.9rem; padding:1.1em 1.8em;">Start a project <span class="arrow">↗</span></a>
    </div>
  </section>
</Base>
